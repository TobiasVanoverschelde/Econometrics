\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Sarsons's critique as a DAG. Same diagram as Figure~\ref {fig:dag-mss}, plus a direct $z \to y_1$ arrow that exclusion denies. Evidence from regions where the $z \to y_2$ channel is physically blocked (downstream of dams) supports the existence of this arrow.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:dag-sarsons}{{2}{3}{Sarsons's critique as a DAG. Same diagram as Figure~\ref {fig:dag-mss}, plus a direct $z \to y_1$ arrow that exclusion denies. Evidence from regions where the $z \to y_2$ channel is physically blocked (downstream of dams) supports the existence of this arrow}{figure.2}{}}
